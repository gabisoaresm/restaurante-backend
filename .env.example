# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA envie o arquivo .env para o GitHub.

# Chave secreta do Django — gere uma nova com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Ativa o modo de depuração — use True apenas em desenvolvimento local, nunca em produção
DEBUG=True

# Hosts permitidos — separados por vírgula, sem espaços
# Desenvolvimento: localhost,127.0.0.1
# Produção: cucinaitaliana.pythonanywhere.com,localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# Ambiente de e-mail: 'console' para desenvolvimento, 'gmail' para produção
EMAIL_BACKEND_TIPO=console

# Credenciais do Gmail (necessárias apenas quando EMAIL_BACKEND_TIPO=gmail)
# Para gerar a senha de app: Conta Google → Segurança → Senhas de app
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# CORS — origens permitidas (separadas por vírgula, sem espaços)
# Desenvolvimento local: http://localhost:8080,http://127.0.0.1:8080
# Produção: substitua/acrescente o domínio do frontend publicado
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
